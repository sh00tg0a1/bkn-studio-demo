# MiniMax — Anthropic 兼容 API
# @ai-sdk/anthropic 会请求 {baseURL}/messages，须与官方一致为 …/v1/messages。
# 可只写 https://api.minimax.io/anthropic（代码会自动补 /v1），或直接写完整：
# LLM_API_BASE=https://api.minimax.io/anthropic/v1
#
# 与 Python SDK 的 ANTHROPIC_BASE_URL 一致时，MiniMax 文档常为 …/anthropic（无 v1），
# Python 客户端内部会处理；本仓库在 agent 里对 …/anthropic 自动追加 /v1。

LLM_API_BASE=https://api.minimax.io/anthropic/v1
LLM_MODEL=MiniMax-M2.7
LLM_API_KEY=your-api-key-here

# 可选：与 shell 中 export 同名
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# ANTHROPIC_API_KEY=your-api-key-here
# ANTHROPIC_MODEL=MiniMax-M2.7

# --- 可选：MySQL Skill 注册表（侧栏「+」创建 Skill、/api/create-skill、列表与 BKN 合并）
# 勿将真实密码提交到 git；与 kweaverc ds connect mysql … hd_supply 使用同一库即可。
# SKILLS_DB_HOST=116.63.205.204
# SKILLS_DB_PORT=3306
# SKILLS_DB_USER=root
# SKILLS_DB_PASSWORD=
# SKILLS_DB_NAME=hd_supply
